# Rasid v6.4 — Environment Configuration
NODE_ENV=production
PORT=3000

# Database
DATABASE_HOST=pgbouncer
DATABASE_PORT=6432
DATABASE_NAME=rasid
DATABASE_USER=rasid
DATABASE_PASSWORD=change-me-in-production
DB_POOL_MAX=3
DB_IDLE_TIMEOUT=30000
DB_LOGGING=false

# JWT
JWT_SECRET=generate-a-strong-random-secret-at-least-64-chars
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800

# Redis
REDIS_URL=redis://redis:6379

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Thresholds
TV_PIXEL_MAX=0.001
TV_STRUCTURAL_MIN=0.999
CONF_AUTO_LOCK=0.98
CONF_REVIEW=0.90
AGG_GPU_THRESHOLD=10000000
CL_MAX_FOCAL=7

# Observability
LOG_LEVEL=info
METRICS_ENABLED=true
TRACING_ENABLED=true

# ═══════════════════════════════════════════════════════
# Phase 3 — New Configuration Variables
# ═══════════════════════════════════════════════════════

# SEC-007: CORS
CORS_ALLOWED_ORIGINS=https://rasid.ndmo.gov.sa,https://admin.rasid.ndmo.gov.sa
CORS_ORIGIN_PATTERNS=^https://.*\.rasid\.ndmo\.gov\.sa$

# SEC-009: Encryption at Rest
ENCRYPTION_MASTER_KEY=CHANGE_ME_TO_RANDOM_32_CHARS_MIN
ENCRYPTION_KEY_ID=rasid-key-v1

# C2: Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MAX_MEMORY=256mb

# C3: Message Queue
MQ_DEFAULT_RETRIES=3
MQ_RETRY_DELAY_MS=1000
MQ_CONCURRENCY=10

# D5: Swagger
ENABLE_SWAGGER=true
API_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX=100

# DB Pool (per connection)
DB_POOL_MAX=3
